{
  "name": "fpure",
  "version": "0.2.0",
  "description": "Pure, curried, functional programming utilities for TypeScript.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test spec/*.test.cjs",
    "coverage": "npm run build && c8 --reporter=lcov --reporter=text node --test spec/*.test.cjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/seancannon/fpure.git"
  },
  "keywords": [
    "fp",
    "functional programming",
    "ramda",
    "haskell",
    "pure functions",
    "pure",
    "fpure",
    "typescript",
    "sanctuary"
  ],
  "author": "Sean Cannon",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/seancannon/fpure/issues"
  },
  "homepage": "https://github.com/seancannon/fpure",
  "devDependencies": {
    "c8": "^11.0.0",
    "typescript": "^6.0.0"
  }
}
